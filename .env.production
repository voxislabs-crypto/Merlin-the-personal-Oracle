# Production Environment Variables
# DO NOT commit this file to version control

# Development Mode - MUST be false in production
NEXT_PUBLIC_DEV_MODE=false

# Clerk Authentication (production keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_production_clerk_publishable_key
CLERK_SECRET_KEY=your_production_clerk_secret_key

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe Payment Processing (production keys)
STRIPE_SECRET_KEY=your_production_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_production_stripe_publishable_key
NEXT_PUBLIC_STRIPE_PRICE_ID=your_production_stripe_price_id

# App URL
NEXT_PUBLIC_URL=https://your-production-domain.com/
