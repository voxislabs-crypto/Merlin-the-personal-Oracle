{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voxislabs.ai/schemas/phase-gate.schema.json",
  "title": "Model Promotion Phase Gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "modelId",
    "evaluationWindow",
    "currentPhase",
    "targetPhase",
    "metrics",
    "gateChecks",
    "approvedBy",
    "rollbackTriggered",
    "decision"
  ],
  "properties": {
    "modelId": {
      "type": "string"
    },
    "evaluationWindow": {
      "type": "string"
    },
    "currentPhase": {
      "type": "string",
      "enum": ["baseline", "stable", "trusted", "adaptive", "autonomous"]
    },
    "targetPhase": {
      "type": "string",
      "enum": ["stable", "trusted", "adaptive", "autonomous"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trustScore",
        "hallucinationRate",
        "emotionalConsistency",
        "responseCoherence",
        "driftScore"
      ],
      "properties": {
        "trustScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "hallucinationRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "emotionalConsistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "responseCoherence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "driftScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "gateChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataReadiness", "offlineUplift", "shadowSafety", "transparency", "rollbackReadiness"],
      "properties": {
        "dataReadiness": { "$ref": "#/$defs/gateCheck" },
        "offlineUplift": { "$ref": "#/$defs/gateCheck" },
        "shadowSafety": { "$ref": "#/$defs/gateCheck" },
        "transparency": { "$ref": "#/$defs/gateCheck" },
        "rollbackReadiness": { "$ref": "#/$defs/gateCheck" }
      }
    },
    "approvedBy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["ops", "safety", "personality-team", "product", "engineering"]
      }
    },
    "rollbackTriggered": {
      "type": "boolean"
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "hold", "reject"]
    },
    "notes": {
      "type": "string"
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "gateCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass", "evidence"],
      "properties": {
        "pass": {
          "type": "boolean"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "failedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
