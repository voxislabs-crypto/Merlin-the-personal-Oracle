You should now be able to deploy anytime by just typing DEPLOY from anywhere on the server.

cat > /opt/voxis/deploy-safe.sh << 'EOF'
#!/bin/bash
set -e  # Exit immediately if any command fails

echo "=== Safe Voxis Deploy Started ==="

cd /opt/voxis

echo "→ Fetching latest changes..."
git fetch origin

echo "→ Stashing any local changes (including untracked files)..."
git stash push -u -m "Pre-deploy auto-stash $(date +%Y-%m-%d_%H-%M-%S)"

echo "→ Checking out NeuronMap branch..."
git checkout NeuronMap 2>/dev/null || git checkout -b NeuronMap origin/NeuronMap

echo "→ Pulling latest code..."
git pull origin NeuronMap --ff-only || git pull origin NeuronMap --rebase

echo "→ Installing dependencies..."
npm install

echo "→ Building frontend..."
npm run build

echo "→ Restarting backend..."
pm2 restart voxis-backend

echo "→ Reloading nginx..."
sudo systemctl reload nginx

echo "→ Cleaning up stash..."
git stash drop || true

echo "=== Safe Voxis Deploy Completed Successfully ==="
EOF

--
or use: 
sudo chown voxis:voxis /opt/voxis/deploy-safe.sh
chmod +x /opt/voxis/deploy-safe.sh
deploy

