# =============================================================================
# Merlin Oracle - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to git!

# =============================================================================
# REQUIRED - Application URL
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3000
# Production: https://your-domain.com

# =============================================================================
# REQUIRED - Clerk Authentication (Secondary Application)
# =============================================================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Clerk custom domain (secondary application)
# Set this in Clerk Dashboard: Configuration → API -> Custom domain
NEXT_PUBLIC_CLERK_CUSTOM_DOMAIN=clerk.merlin.voxislabs.com

# Satellite app configuration - tells Clerk this is a secondary application
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_DOMAIN=merlin.voxislabs.com

# Clerk redirect URLs (updated to new prop names)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk email configuration (secondary application)
# This should match your verified sender domain
CLERK_EMAIL_DOMAIN=merlin.voxislabs.com

# =============================================================================
# REQUIRED - Stripe Payment Processing
# =============================================================================
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Stripe webhook secret (get from https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Your product price ID (create in Stripe Dashboard -> Products)
NEXT_PUBLIC_STRIPE_PRICE_ID=price_xxxxxxxxxxxxx

# Monthly subscription with 7-day free trial
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_1T1qy8R70Fi1RV0weNuc6vPD

# Stripe Direct Payment Link (created in Stripe Dashboard -> Payment Links)
# This is a hosted checkout page that requires no backend code
# Example: https://buy.stripe.com/test_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxxxxxxxxxxxx

# =============================================================================
# OPTIONAL - Email Service (Resend)
# =============================================================================
# Resend API key for transactional emails (trial ending, payment failed, etc.)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email "from" address (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# OPTIONAL - Analytics & Conversion Tracking
# =============================================================================
# Google Analytics 4 (highly recommended for tracking conversions)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Facebook/Meta Pixel (recommended for retargeting)
NEXT_PUBLIC_FB_PIXEL_ID=123456789012345

# =============================================================================
# OPTIONAL - Email Marketing (choose one)
# =============================================================================
# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_LIST_ID=your_list_id
MAILCHIMP_SERVER_PREFIX=us6

# OR ConvertKit
CONVERTKIT_API_KEY=your_convertkit_key
CONVERTKIT_FORM_ID=your_form_id

# OR Klaviyo
KLAVIYO_API_KEY=your_klaviyo_api_key
KLAVIYO_LIST_ID=your_list_id

# =============================================================================
# OPTIONAL - AI/LLM for Enhanced Interpretations
# =============================================================================
# OpenAI GPT (for Grok-style interpretations)
OPENAI_API_KEY=sk-your_openai_key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# xAI Grok API (for AI-powered chart interpretations)
XAI_API_KEY=your_xai_api_key

# CAFE Router (OpenAI-compatible gateway)
# You can point these to your DigitalOcean-hosted model gateway or any compatible endpoint.
# For OpenAI-compatible APIs, set URL to /v1/chat/completions.
CAFE_LLM_API_URL=
CAFE_LLM_API_KEY=
CAFE_LLM_MODEL=
CAFE_LLM_PROVIDER=

# Merlin gateway key for server-to-server CAFE access
# Used by the dedicated `/api/cafe/forecast` route
MERLIN_GATEWAY_KEY=

# Optional explicit local/remote split (overrides generic CAFE_LLM_* values)
CAFE_LOCAL_API_URL=
CAFE_LOCAL_API_KEY=
CAFE_LOCAL_MODEL=
CAFE_LOCAL_PROVIDER=
CAFE_REMOTE_API_URL=
CAFE_REMOTE_API_KEY=
CAFE_REMOTE_MODEL=
CAFE_REMOTE_PROVIDER=

# =============================================================================
# OPTIONAL - Database (if using Prisma for user data)
# =============================================================================
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to 'true' to bypass payment in development (useful for testing)
NEXT_PUBLIC_DEV_MODE=true

# Node environment
NODE_ENV=development

# =============================================================================
# OPTIONAL - Additional Services
# =============================================================================
# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_public_sentry_dsn

# PostHog Product Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# 🚀 QUICK START GUIDE
# =============================================================================
# 
# MINIMUM REQUIRED FOR DEVELOPMENT:
# 1. Copy this file: cp .env.example .env.local
# 2. Set NEXT_PUBLIC_DEV_MODE=true (bypasses payments)
# 3. Get free Clerk keys: https://dashboard.clerk.com
# 4. Get Stripe test keys: https://dashboard.stripe.com/test/apikeys
# 5. Run: npm run dev
#
# MINIMUM REQUIRED FOR PRODUCTION:
# 1. All Clerk keys (production mode)
# 2. All Stripe keys (live mode) + webhook secret
# 3. NEXT_PUBLIC_URL set to your domain
# 4. Set NEXT_PUBLIC_DEV_MODE=false or remove it
#
# RECOMMENDED FOR MONETIZATION:
# 1. Add NEXT_PUBLIC_GA_ID for conversion tracking
# 2. Add NEXT_PUBLIC_FB_PIXEL_ID for retargeting
# 3. Add email marketing service (Mailchimp/ConvertKit/Klaviyo)
# 4. Set up Stripe webhook: stripe listen --forward-to localhost:3000/api/stripe/webhook
#
# TEST CREDIT CARD (Stripe Test Mode):
# Card: 4242 4242 4242 4242
# Expiry: Any future date
# CVC: Any 3 digits
# ZIP: Any 5 digits
#
# =============================================================================

