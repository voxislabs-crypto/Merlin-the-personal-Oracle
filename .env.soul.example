# Soul Layer Environment Variables

# ElevenLabs TTS API (for voice mode)
# Get your API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# PlayHT TTS API (alternative voice provider)
# Get your credentials from: https://play.ht/
PLAYHT_API_KEY=your_playht_api_key_here
PLAYHT_USER_ID=your_playht_user_id_here

# Note: Voice mode is optional - all other soul features work without TTS credentials
