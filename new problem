import React, { useEffect, useState } from "react";

export default function DebugOverlay({ brain }: any) {
  const [state, setState] = useState<any>(null);

  useEffect(() => {
    brain.onUpdate(setState);
  }, []);

  if (!state) return null;

  return (
    <div style={{
      position: "absolute",
      top: 0,
      right: 0,
      width: "320px",
      background: "rgba(0,0,0,0.7)",
      color: "#0ff",
      padding: "10px",
      fontSize: "12px",
      fontFamily: "monospace"
    }}>
      <h3>VOXIS EMOTION GRAPH</h3>

      {Object.entries(state.emotions).map(([id, node]: any) => (
        <div key={id}>
          {id}: {node.current.toFixed(2)} | drift {node.drift.toFixed(2)}
        </div>
      ))}

      <hr />

      <div>
        <b>SINGING:</b> {state.singing ? "YES 🔥" : "no"}
      </div>

      <div>
        <b>AUDIO INTENSITY:</b> {state.audioState.intensity.toFixed(2)}
      </div>
    </div>
  );
}
