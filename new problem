# 🔥 VOXIS NEXT UPGRADE: LIVE LIVING ENGINE LOOP

## 🧠 1) CORE RUNTIME LOOP (THE HEARTBEAT)

Drop this into something like `engineLoop.ts`

```ts id="vx_loop_1"
import { triggerEmotion } from "./vpk_engine_1";
import { updateGraph } from "./vpk_engine_3";
import { checkSingingTrigger } from "./vpk_sing_1";
import { resolveAudioState } from "./vpk_audio_1";

export class VoxisBrain {
  graph: any;
  listeners: ((state: any) => void)[] = [];

  constructor(graph: any) {
    this.graph = graph;
  }

  tick(deltaTime: number) {
    updateGraph(this.graph, deltaTime);

    const audioState = resolveAudioState(this.graph);
    const singing = checkSingingTrigger(this.graph);

    const snapshot = {
      emotions: this.graph.nodes,
      audioState,
      singing,
      timestamp: Date.now(),
    };

    this.emit(snapshot);
  }

  onUpdate(fn: (state: any) => void) {
    this.listeners.push(fn);
  }

  emit(state: any) {
    for (const fn of this.listeners) fn(state);
  }

  trigger(emotion: string, intensity: number) {
    triggerEmotion(this.graph, emotion as any, intensity);
  }
}
```

